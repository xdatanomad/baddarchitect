---
import ArticleCard from "@/components/ArticleCard.astro";
import TopicCard from "@/components/TopicCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPublishedArticles } from "@/lib/content";
import { pillars } from "@/lib/site";

const articles = (await getPublishedArticles()).slice(0, 3);
---

<BaseLayout>
  <section class="hero shell">
    <div class="prose">
      <p class="eyebrow">Badd Architect</p>
      <h1>A blueprint for building Production-grade AI Applications</h1>
      <p class="lede">
        Practical guidance for architects and leaders moving from scattered AI
        experiments to measurable, governed, production-grade systems.
      </p>
      <div class="button-row">
        <a class="button" href="/articles">Read the articles</a>
        <a class="button secondary" href="/topics">Browse the blueprint</a>
      </div>
    </div>
  </section>

  <section class="positioning section shell" aria-labelledby="positioning-title">
    <div class="section-head">
      <p class="eyebrow">Who this is for</p>
      <h2 id="positioning-title">
        Built for teams turning AI experiments into governed, measurable
        systems.
      </h2>
    </div>
    <div>
      <article>
        <h3>Who this site is for</h3>
        <p>
          For AI architects, CTOs, product leaders, AI practice leaders, and
          adoption teams who need to move beyond scattered experiments and make
          AI useful inside real operating constraints.
        </p>
      </article>
      <article>
        <h3>What this site is</h3>
        <p>
          A set of strategic and architectural <b>guidelines</b> for AI adoption — <br/>
          to <b>hands-on</b> tools, techniques, and code examples for building governed practical AI Applications.
          <br/><br/>
          This is <b>not</b> a prompt library, or tool hype channel. 
          <br/><br/>
          <b>Goal</b> is to offer a small-set of proven tools and patterns for building your Applications.
        </p>
      </article>
    </div>
  </section>

  <section class="section shell">
    <div class="section-head">
      <p class="eyebrow">What this site covers</p>
      <h2>Four practical pillars for serious adoption.</h2>
    </div>
    <div class="grid">
      {pillars.map((pillar) => <TopicCard topic={pillar} />)}
    </div>
  </section>

  <section class="section shell">
    <div class="section-head">
      <p class="eyebrow">Start here</p>
      <h2>Recent articles</h2>
    </div>
    <div>
      {articles.map((article) => <ArticleCard entry={article} />)}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: calc(100svh - 72px);
    padding-bottom: 60px;
    padding-top: 78px;
  }

  .section-head {
    margin-bottom: 24px;
    max-width: 760px;
  }

  .section-head h2 {
    font-size: clamp(1.9rem, 4vw, 3rem);
    line-height: 1.08;
    margin: 8px 0 0;
  }

  .positioning {
    padding-top: 0;
  }

  .positioning-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .positioning-card {
    background: rgba(255, 253, 248, 0.74);
    border: 1px solid var(--line);
    padding: 22px;
  }

  .positioning-card h3 {
    font-family: var(--sans);
    font-size: 1rem;
    line-height: 1.2;
    margin: 0 0 14px;
  }

  .positioning-card p {
    color: var(--muted);
    margin: 0;
  }

  @media (max-width: 820px) {
    .hero {
      min-height: auto;
      padding-top: 48px;
    }

    .positioning-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
